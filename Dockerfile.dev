# Development image for the Next.js web app inside docker-compose (--profile full).
# Source is mounted at runtime via a bind volume, so hot-reload works.
# For production, use apps/web/Dockerfile instead.
#
# Rebuild when package.json files change:
#   docker compose --profile full build web

FROM node:22-alpine

RUN apk add --no-cache curl

# Install the exact pnpm version declared in package.json#packageManager
RUN npm install -g pnpm@11.1.3

WORKDIR /app

# Copy workspace manifests first — Docker caches this layer until deps change
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml turbo.json ./
COPY packages/types/package.json              ./packages/types/
COPY packages/ui/package.json                 ./packages/ui/
COPY packages/db/package.json                 ./packages/db/
COPY packages/ecu-parser-wasm/package.json    ./packages/ecu-parser-wasm/
COPY packages/typescript-config/package.json  ./packages/typescript-config/
COPY apps/web/package.json                    ./apps/web/

RUN pnpm install --frozen-lockfile

EXPOSE 3000

# Source is mounted via volume at runtime (see docker-compose.yml).
# node_modules stays from the build layer via the web_modules named volume.
CMD ["pnpm", "--filter", "@maplab/web", "dev"]
