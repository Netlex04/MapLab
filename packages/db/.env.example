# Supabase → Settings → Database → Connection string
#
# "Transaction" mode (Port 6543) — for Prisma runtime queries (via PgBouncer)
DATABASE_URL="postgresql://postgres.zbftlzlepymfwfjvuguc:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# "Session" mode (Port 5432) — for Prisma migrations (direct connection)
DIRECT_URL="postgresql://postgres.zbftlzlepymfwfjvuguc:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
